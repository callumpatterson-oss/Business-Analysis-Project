SELECT
    o.order_id,
    o.order_date,
    c.customer_name,
    c.country,
    p.product_name,
    cat.category_name,
    s.supplier_name,
    oi.quantity,
    oi.unit_price,
    oi.discount_pct,
    ROUND(
        oi.quantity *
        oi.unit_price *
        (1 - oi.discount_pct/100.0),
        2
    ) AS revenue
FROM order_items oi
JOIN orders o
    ON oi.order_id = o.order_id
JOIN customers c
    ON o.customer_id = c.customer_id
JOIN products p
    ON oi.product_id = p.product_id
JOIN categories cat
    ON p.category_id = cat.category_id
JOIN suppliers s
    ON p.supplier_id = s.supplier_id;
